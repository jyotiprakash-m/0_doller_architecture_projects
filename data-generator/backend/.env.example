# --- JWT Auth ---
JWT_SECRET_KEY=synth-data-gen-secret-key-change-this

# --- Stripe (Payment Gateway) ---
# Stripe is used for SaaS monetization (purchasing credits)
STRIPE_API_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# --- Data Generation ---
# Limits on how many rows can be generated per table
MAX_ROWS_PER_TABLE=1000000
DEFAULT_BATCH_SIZE=5000
